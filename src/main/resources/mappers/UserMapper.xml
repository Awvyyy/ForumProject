<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.repppp.mappers.UserMapper">

    <resultMap id="UserResultMap" type="AppUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="reputation" column="reputation"/>
    </resultMap>

    <select id="findById" resultMap="UserResultMap">
        SELECT id, username, password_hash, reputation
        FROM users
        WHERE id = #{id}
    </select>

    <select id="findByUsername" resultMap="UserResultMap">
        SELECT id, username, password_hash, reputation
        FROM users
        WHERE username = #{username}
    </select>

    <insert id="insert"
            parameterType="AppUser"
            useGeneratedKeys="true"
            keyProperty="id"
            keyColumn="id">
        INSERT INTO users (username, password_hash, reputation)
        VALUES (#{username}, #{passwordHash}, #{reputation})
    </insert>

    <update id="updateReputation">
        UPDATE users
        SET reputation = #{reputation}
        WHERE id = #{id}
    </update>

</mapper>